# ─────────────────────────────────────────────────────────────
# Firebase / Firestore configuration (migration off PostgreSQL)
# Pick ONE of the three options below and add it to backend/.env
# ─────────────────────────────────────────────────────────────

# Option A — Local emulator (no Google Cloud account needed; requires Java + firebase-tools)
#   Run:  firebase emulators:start --only firestore
# FIREBASE_PROJECT_ID=erp-system-local
# FIRESTORE_EMULATOR_HOST=localhost:8080

# Option B — Service account via env vars (real Firebase project, Firestore enabled)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# Option C — Service account JSON file (download from Firebase console → Project settings → Service accounts)
#   Place the file at backend/serviceAccountKey.json (git-ignored) OR set the path below.
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
