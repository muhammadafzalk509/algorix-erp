rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // All access is mediated by the trusted NestJS backend, which uses the
    // Firebase Admin SDK and bypasses these rules. Direct client access is
    // denied. (Open this up only if the frontend ever talks to Firestore.)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
